{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4",
  "autoupdate": true,
  "snapshot": true,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      "target/**",
      "_build/**",
      "deps/**"
    ]
  },
  "permission": {
    "*": "allow",
    "bash": "ask"
  }
}
