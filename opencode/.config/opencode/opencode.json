{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.4-mini",
  "autoupdate": true,
  "snapshot": true,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      "target/**",
      "_build/**",
      "deps/**"
    ]
  },
  "permission": {
    "*": "allow",
    "bash": "ask",
    "read": {
      "~/.config/opencode/get-shit-done/*": "allow"
    },
    "external_directory": {
      "~/.config/opencode/get-shit-done/*": "allow"
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "XcodeBuildMCP": {
      "type": "local",
      "command": ["/opt/homebrew/bin/xcodebuildmcp", "mcp"],
      "enabled": true
    },
    "gsc": {
      "type": "local",
      "command": ["/opt/homebrew/bin/uvx", "mcp-search-console"],
      "environment": {
        "GSC_OAUTH_CLIENT_SECRETS_FILE": "/Users/wulymammoth/dotfiles/gsc_mcp_client_secret.json"
      },
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
    "stitch": {
      "type": "local",
      "command": ["node", "/Users/wulymammoth/.config/opencode/bin/stitch-mcp-proxy.mjs"],
      "environment": {
        "STITCH_API_KEY": "{env:STITCH_API_KEY}"
      },
      "timeout": 30000,
      "enabled": true
    },
    "vercel": {
      "type": "remote",
      "url": "https://mcp.vercel.com",
      "enabled": true
    },
    "posthog": {
      "type": "remote",
      "url": "https://mcp.posthog.com/mcp",
      "enabled": true
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
      "enabled": true
    },
    "linear": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.linear.app/mcp"
      ],
      "enabled": true
    }
  },
  "provider": {
    "openai": {
      "options": {
        "baseURL": "http://127.0.0.1:2455/v1",
        "apiKey": "{env:CODEX_LB_API_KEY}"
      },
      "models": {
        "gpt-5.5": {
          "name": "GPT-5.5",
          "reasoning": true,
          "options": {
            "reasoningSummary": "detailed"
          },
          "variants": {
            "none": {
              "disabled": true
            },
            "minimal": {
              "disabled": true
            },
            "low": {
              "disabled": true
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "detailed"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "detailed"
            }
          },
          "limit": {
            "context": 1050000,
            "output": 128000
          }
        },
        "gpt-5.4-mini": {
          "name": "GPT-5.4 Mini",
          "reasoning": true,
          "options": {
            "reasoningEffort": "high",
            "reasoningSummary": "detailed"
          },
          "limit": {
            "context": 400000,
            "output": 65536
          }
        },
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex",
          "reasoning": true,
          "options": {
            "reasoningEffort": "high",
            "reasoningSummary": "detailed"
          },
          "limit": {
            "context": 272000,
            "output": 65536
          }
        },
        "gpt-5.1-codex-mini": {
          "name": "GPT-5.1 Codex Mini",
          "reasoning": true,
          "options": {
            "reasoningEffort": "high",
            "reasoningSummary": "detailed"
          },
          "limit": {
            "context": 272000,
            "output": 65536
          }
        },
        "gpt-5.3-codex-spark": {
          "name": "GPT-5.3 Codex Spark",
          "reasoning": true,
          "options": {
            "reasoningEffort": "xhigh",
            "reasoningSummary": "detailed"
          },
          "limit": {
            "context": 128000,
            "output": 65536
          }
        }
      }
    }
  }
}
