{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-5.4-mini",
  "autoupdate": true,
  "snapshot": true,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      "target/**",
      "_build/**",
      "deps/**"
    ]
  },
  "permission": {
    "*": "allow",
    "bash": "ask"
  },
  "provider": {
    "openai": {
      "options": {
        "baseURL": "http://127.0.0.1:2455/v1",
        "apiKey": "{env:CODEX_LB_API_KEY}"
      },
      "models": {
        "gpt-5.4": {
          "name": "GPT-5.4",
          "reasoning": true,
          "options": {
            "reasoningEffort": "medium",
            "reasoningSummary": "detailed"
          },
          "limit": {
            "context": 1050000,
            "output": 128000
          }
        },
        "gpt-5.4-mini": {
          "name": "GPT-5.4 Mini",
          "reasoning": true,
          "options": {
            "reasoningEffort": "high",
            "reasoningSummary": "detailed"
          },
          "limit": {
            "context": 400000,
            "output": 65536
          }
        },
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex",
          "reasoning": true,
          "options": {
            "reasoningEffort": "high",
            "reasoningSummary": "detailed"
          },
          "limit": {
            "context": 272000,
            "output": 65536
          }
        },
        "gpt-5.1-codex-mini": {
          "name": "GPT-5.1 Codex Mini",
          "reasoning": true,
          "options": {
            "reasoningEffort": "high",
            "reasoningSummary": "detailed"
          },
          "limit": {
            "context": 272000,
            "output": 65536
          }
        },
        "gpt-5.3-codex-spark": {
          "name": "GPT-5.3 Codex Spark",
          "reasoning": true,
          "options": {
            "reasoningEffort": "xhigh",
            "reasoningSummary": "detailed"
          },
          "limit": {
            "context": 128000,
            "output": 65536
          }
        }
      }
    }
  }
}
